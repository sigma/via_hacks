DEVENV_VERSION="2.0.4"

# Fetch pinned devenv and prepend to PATH
DEVENV_PATH=$(nix build "github:cachix/devenv/v${DEVENV_VERSION}" --accept-flake-config --no-link --print-out-paths 2>/dev/null)
if [ -n "$DEVENV_PATH" ]; then
  PATH_add "$DEVENV_PATH/bin"
fi

eval "$(devenv direnvrc)"

use devenv --quiet
